{
  "servers": {
    "deepcontext-docker": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--workdir",
        "/app",
        "--entrypoint",
        "node",
        "-v",
        "/Users/mac/Documents/HungLD/graphdocument/docs/source:/workspace/source",
        "-v",
        "/Users/mac/Documents/HungLD/graphdocument/docs/md:/workspace/docs/md",
        "-v",
        "/Users/mac/Documents/HungLD/graphdocument/docs/raw:/workspace/docs/raw",
        "-e",
        "OLLAMA_HOST=http://host.docker.internal:11434",
        "-e",
        "OLLAMA_EMBED_MODEL=nomic-embed-text",
        "-e",
        "OLLAMA_CHAT_MODEL=llama3.2",
        "-e",
        "DEEPCONTEXT_EMBED_BATCH_SIZE=8",
        "-e",
        "DEEPCONTEXT_EMBED_TRACKER=lazy",
        "-e",
        "DEEPCONTEXT_MARKITDOWN_BIN=/opt/markitdown/bin/markitdown",
        "hungld7/deepcontext:0.9.1",
        "/app/build/index.js",
        "/workspace"
      ],
      "env": {}
    }
  },
  "inputs": []
}